{
  "name": "agent-cartridge",
  "version": "0.1.1-rc.1",
  "description": "ACX (Agent Cartridge eXchange) — the open standard + zero-dependency reference implementation for portable, self-improving AI agents that learn, level up, form teams, and run workflows.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://lboel.github.io/acx/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lboel/acx.git"
  },
  "bugs": {
    "url": "https://github.com/lboel/acx/issues"
  },
  "author": "The Agent Cartridge authors",
  "bin": {
    "acx": "src/cli.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "files": [
    "src/",
    "schemas/",
    "skills/",
    "examples/sample-agent-package/*.md",
    "examples/sample-agent-package/*.json",
    "examples/sample-agent-package/*.yaml",
    "examples/sample-agent-package/checksum.sha256",
    "examples/product-delivery.agent-graph.json",
    "platform/README.md",
    "platform/static/",
    "registry/README.md",
    "registry/index.json",
    "registry/status.json",
    "registry/cals/",
    "registry/cartridges/",
    "registry/graphs/",
    "registry/templates/",
    "tools/check-registry-immutability.mjs",
    "tools/check-static-site.mjs",
    "tools/build-registry-index.mjs",
    "tools/build-static-exchange.mjs",
    "tools/materialize-lance.mjs",
    "tools/lance/README.md",
    "tools/lance/materialize.py",
    "SPEC.md",
    "AGENTS.md",
    "README.md",
    "CHANGELOG.md",
    "GOVERNANCE.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "CITATION.cff",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "test": "node --experimental-sqlite --test 'test/*.test.mjs'",
    "test:workflow": "node --experimental-sqlite --test test/workflow.test.mjs",
    "smoke": "node --experimental-sqlite scripts/smoke.mjs",
    "smoke:package": "node scripts/smoke-package.mjs",
    "acx": "node --experimental-sqlite src/cli.mjs",
    "build:registry": "node --experimental-sqlite tools/build-registry-index.mjs",
    "build:exchange": "npm run build:registry && node --experimental-sqlite tools/build-static-exchange.mjs",
    "build:docs-social": "node tools/inject-docs-social.mjs --site docs-site/site --site-url https://lboel.github.io/acx/",
    "check:site": "node tools/check-static-site.mjs --site docs-site/site --base-path /acx/",
    "build": "npm run build:exchange"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "agent",
    "cartridge",
    "acx",
    "ai-agent",
    "portable-agent",
    "agent-workflow",
    "agent-graph",
    "agent-team",
    "multi-agent",
    "agent-orchestration",
    "knowledge-routing",
    "team-communication",
    "agent-skills",
    "mcp",
    "sqlite",
    "lancedb",
    "dsse",
    "verifiable-credential",
    "open-standard"
  ]
}
