{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acx.dev/schema/lance-memory.v1.json",
  "title": "ACX LanceDB Memory Schema (acx.lance-memory/1)",
  "description": "The fixed, normative LanceDB table schema for the optional vector memory payload. Columns map 1:1 to acx.memory-record.v1; the JSON baseline is authoritative and this table is a derived, never-signed, re-indexable projection.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "format", "table", "embeddingEngine", "distanceMetric", "columns"],
  "properties": {
    "schemaVersion": { "const": "acx.lance-memory/1" },
    "format": { "const": "lancedb" },
    "table": { "const": "memories" },
    "partitionBy": { "const": "zone" },
    "distanceMetric": { "const": "cosine" },
    "textTemplate": { "type": "string" },
    "embeddingEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "dim"],
      "properties": { "id": { "type": "string" }, "dim": { "type": "integer", "minimum": 1 } }
    },
    "columns": {
      "type": "array",
      "minItems": 14,
      "items": {
        "type": "object",
        "required": ["name", "type", "nullable"],
        "properties": {
          "name": { "enum": ["id", "zone", "portable", "artifact_fingerprint", "codebase_fingerprint", "title", "summary", "source_type", "tags", "impact", "xp_awarded", "timestamp", "text", "vector"] },
          "type": { "type": "string" },
          "nullable": { "type": "boolean" },
          "enum": { "type": "array" }
        }
      }
    }
  }
}
