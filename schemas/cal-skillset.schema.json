{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acx.dev/schema/cal-skillset.v1.json",
  "title": "ACX CAL Skill Set (acx.cal-skillset/1)",
  "description": "The ROM-signed team/workflow participation declaration stored in a cartridge.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "plays"],
  "properties": {
    "schemaVersion": { "const": "acx.cal-skillset/1" },
    "plays": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role"],
        "properties": {
          "role": { "type": "string", "minLength": 1 },
          "providesCapabilities": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "canComplete": {
            "type": "array",
            "uniqueItems": true,
            "description": "Skill names this agent can run to completion.",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "references": {
      "type": "array",
      "description": "Other agents this cartridge hands off to, pinned by signed ROM digest.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alias", "romDigest"],
        "properties": {
          "alias": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$" },
          "romDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "role": { "type": "string", "minLength": 1 }
        }
      }
    },
    "processes": {
      "type": "array",
      "uniqueItems": true,
      "description": "ACX workflow ids this agent participates in.",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$" }
    }
  }
}
